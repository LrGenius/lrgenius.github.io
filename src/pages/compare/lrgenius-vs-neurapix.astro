---
import Layout from '../../layouts/Layout.astro';

const title = 'LrGenius vs. Neurapix (2026)';
const description = 'Neurapix trains on your existing Lightroom edits to recreate your personal style via SmartPresets. LrGenius takes a different approach: free, open-source, and built into Lightroom Classic with AI keywording, semantic search, culling, and no subscription fee.';
const lastUpdated = '2026-06-01';
---

<Layout title={`${title} — AI Editing Comparison for Lightroom`} description={description}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": lastUpdated,
    "dateModified": lastUpdated,
    "author": { "@type": "Organization", "name": "LrGenius", "url": "https://lrgenius.com" },
    "about": [
      { "@type": "SoftwareApplication", "name": "LrGeniusAI" },
      { "@type": "SoftwareApplication", "name": "Neurapix" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lrgenius.com" },
      { "@type": "ListItem", "position": 2, "name": "Compare AI Plugins", "item": "https://lrgenius.com/compare" },
      { "@type": "ListItem", "position": 3, "name": "LrGenius vs. Neurapix", "item": "https://lrgenius.com/compare/lrgenius-vs-neurapix" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is LrGenius a good alternative to Neurapix?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "They address different needs. Neurapix is a cloud-based editing tool that analyzes your existing Lightroom presets and applies a matching style to new photos — focused purely on editing efficiency. LrGenius is free, open-source, and covers AI keywording, semantic search, culling, face recognition, and experimental editing in one Lightroom plugin, with the option to run entirely on your own hardware. If AI editing is your only requirement, Neurapix is more mature in that area. If you need a broader, free, privacy-friendly AI workflow, LrGenius covers more ground."
        }
      },
      {
        "@type": "Question",
        "name": "Does Neurapix do AI keywording or photo culling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Neurapix is focused on AI editing using SmartPresets. It does not generate keywords, captions, or perform photo culling and selection. LrGeniusAI covers all of those features."
        }
      },
      {
        "@type": "Question",
        "name": "Is Neurapix free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Neurapix charges per image or via a subscription plan. LrGeniusAI is completely free and open-source (AGPL-3.0). Local processing via Ollama or LM Studio has no per-image cost."
        }
      }
    ]
  })} />

  <section class="hero compact">
    <h1>LrGenius vs. Neurapix</h1>
    <p class="tagline">Free all-in-one AI plugin vs. cloud AI editing with SmartPresets.</p>
    <p class="meta">Last updated: {lastUpdated}</p>
  </section>

  <section class="verdict">
    <h2>Quick verdict</h2>
    <p>
      <strong>Choose Neurapix</strong> if AI editing is your primary goal — specifically applying a consistent
      style across large batches of photos using cloud-based SmartPresets that adapt to your existing Lightroom
      look. Neurapix is designed for editing efficiency.
    </p>
    <p>
      <strong>Choose LrGeniusAI</strong> if you want AI keywording, semantic search, culling, and editing in
      one free, open-source Lightroom plugin that can run 100% locally. LrGeniusAI's editing "Looks" feature
      is still experimental but costs nothing, and the rest of the workflow (keywording, search, culling) is
      not offered by Neurapix at all.
    </p>
  </section>

  <section class="comparison">
    <h2>Feature comparison</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Aspect</th>
            <th>LrGeniusAI <span class="badge">beta</span></th>
            <th>Neurapix</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Primary purpose</td>
            <td>Keywording, captions, search, culling, edit training</td>
            <td>AI editing — SmartPresets matching your existing style</td>
          </tr>
          <tr>
            <td>Lightroom integration</td>
            <td>Plugin (runs inside Lightroom)</td>
            <td>Cloud service with Lightroom plugin</td>
          </tr>
          <tr>
            <td>AI keywording</td>
            <td>Yes — open-vocabulary, prompt-tunable</td>
            <td>No</td>
          </tr>
          <tr>
            <td>AI captions / titles / alt-text</td>
            <td>Yes</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Semantic / natural-language search</td>
            <td>Yes</td>
            <td>No</td>
          </tr>
          <tr>
            <td>AI culling</td>
            <td>Yes, face-aware (beta)</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Learns personal editing style</td>
            <td>"Looks" — experimental</td>
            <td>Yes — SmartPresets, cloud-trained</td>
          </tr>
          <tr>
            <td>Runs locally / offline</td>
            <td>Yes (Ollama, LM Studio)</td>
            <td>No — cloud only</td>
          </tr>
          <tr>
            <td>Privacy</td>
            <td>Full local option — photos never leave your machine</td>
            <td>Photos uploaded to cloud for processing</td>
          </tr>
          <tr>
            <td>Platform</td>
            <td>macOS + Windows</td>
            <td>macOS + Windows</td>
          </tr>
          <tr>
            <td>Open source</td>
            <td>Yes (AGPL-3.0)</td>
            <td>No</td>
          </tr>
          <tr>
            <td>Pricing</td>
            <td>Free</td>
            <td>Pay-per-image or subscription</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="detail">
    <h2>Where each tool excels</h2>

    <h3>Neurapix: cloud AI editing with SmartPresets</h3>
    <p>
      Neurapix analyzes your existing Lightroom presets and edits to build a SmartPreset tailored to your
      style. When you process a new batch, Neurapix applies that look in the cloud and delivers results back
      to Lightroom. It is a cloud-only, edit-focused service suited to photographers who process large volumes
      and want editing consistency without manual adjustment on each image.
    </p>

    <h3>LrGeniusAI: broader workflow, zero cost</h3>
    <p>
      LrGeniusAI is a Lightroom Classic plugin — not a separate app or cloud service — that covers AI
      keywording, captions, semantic search, culling, face recognition, and experimental edit recipes at
      no cost. Processing can run entirely on your own hardware via Ollama or LM Studio, keeping photos
      off external servers. Neurapix's editing is more mature; LrGeniusAI's breadth of workflow features
      and zero cost make it the stronger fit if you need more than editing alone.
    </p>
  </section>

  <nav class="related-comparisons">
    <h2>Other comparisons</h2>
    <ul>
      <li><a href="/compare">All AI plugins for Lightroom — comparison hub</a></li>
      <li><a href="/lrgenius-vs-excire">LrGenius vs. Excire, Aftershoot, Imagen &amp; more — full overview</a></li>
      <li><a href="/compare/lrgenius-vs-imagen-ai">LrGenius vs. Imagen AI</a></li>
      <li><a href="/compare/lrgenius-vs-aftershoot">LrGenius vs. Aftershoot</a></li>
    </ul>
  </nav>

</Layout>

<style>
  .hero.compact {
    text-align: center;
    padding: 3rem 0 1rem;
  }
  .tagline {
    font-size: 1.25rem;
    color: #666;
    margin-bottom: 0.25rem;
  }
  .meta {
    color: #888;
    font-size: 0.9rem;
  }
  .verdict, .comparison, .detail, .related-comparisons {
    padding: 1.5rem 0;
  }
  .table-wrap {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 1rem;
    font-size: 0.92rem;
  }
  th, td {
    border: 1px solid #eaeaea;
    padding: 0.55rem 0.7rem;
    text-align: left;
    vertical-align: top;
  }
  th {
    background: #f7f7f9;
    white-space: nowrap;
  }
  td:first-child, th:first-child {
    position: sticky;
    left: 0;
    background: #f7f7f9;
    z-index: 1;
  }
  .badge {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    background: #d8a73a;
    color: #fff;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    vertical-align: middle;
    margin-left: 0.3rem;
    text-transform: uppercase;
  }
  h3 {
    margin-top: 1.5rem;
  }
  .related-comparisons ul {
    list-style: none;
    padding: 0;
  }
  .related-comparisons li {
    margin-bottom: 0.6rem;
  }
</style>
