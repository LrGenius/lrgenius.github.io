---
import Layout from '../layouts/Layout.astro';

const title = 'LrGenius vs. Excire, AnyVision, Peakto, Aftershoot, Narrative, Imagen & Neurapix — Honest Comparison';
const description = 'How LrGenius compares to Excire Search, AnyVision, Peakto, Aftershoot, Narrative Select, Imagen AI and Neurapix for AI-powered keywording, search, culling and editing in Adobe Lightroom Classic.';

const lastUpdated = '2026-05-26';
---

<Layout title={title} description={description}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": lastUpdated,
    "dateModified": lastUpdated,
    "author": { "@type": "Organization", "name": "LrGenius" },
    "about": [
      { "@type": "SoftwareApplication", "name": "LrGenius" },
      { "@type": "Thing", "name": "Excire Search" },
      { "@type": "Thing", "name": "AnyVision (Lightroom plugin)" },
      { "@type": "Thing", "name": "Peakto" },
      { "@type": "Thing", "name": "Aftershoot" },
      { "@type": "Thing", "name": "Narrative Select" },
      { "@type": "Thing", "name": "Imagen AI" },
      { "@type": "Thing", "name": "Neurapix" },
      { "@type": "Thing", "name": "LrToolbox (ObviousIdea)" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best AI plugin for Adobe Lightroom Classic?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It depends on the task. For AI culling of weddings or events, Aftershoot and Narrative Select are mature, established options. For keywording and search, Excire Search and AnyVision are well established. For AI editing in your personal style, Imagen AI and Neurapix are widely used. LrGenius is a younger, free, open-source plugin currently in beta that aims to combine AI keywording, descriptions, semantic search, face recognition, edit training and culling — useful if you want an open alternative and are willing to work with a project that is still maturing."
        }
      },
      {
        "@type": "Question",
        "name": "Is LrGenius production-ready?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "LrGenius is currently in beta and under active development. The installers are not yet code-signed, and individual features are at different levels of maturity. We recommend testing it on a copy of your catalog and verifying results before relying on it for paid client work."
        }
      },
      {
        "@type": "Question",
        "name": "Does LrGenius run fully offline?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you configure a local provider such as Ollama or LM Studio, image analysis runs on your own hardware and no photo data leaves your computer. Cloud providers (ChatGPT, Google Gemini, Vertex AI) are optional."
        }
      },
      {
        "@type": "Question",
        "name": "Is LrGenius free?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. LrGenius is free and open-source. If you use a cloud AI provider, the provider's API usage is billed directly by that provider."
        }
      },
      {
        "@type": "Question",
        "name": "Can LrGenius replace Excire Search today?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Possibly, depending on your needs and tolerance for beta software. LrGenius covers AI keywording, semantic search and face recognition in a similar problem space as Excire Search, and adds AI-generated captions, titles and experimental edit training. Excire is more polished and supported, with a curated keyword taxonomy and vendor support — many photographers will still prefer it for production work."
        }
      }
    ]
  })} />

  <section class="hero compact">
    <h1>LrGenius vs. Excire, AnyVision, Peakto, Aftershoot, Narrative &amp; Imagen</h1>
    <p class="tagline">An honest comparison of AI tools around Adobe Lightroom Classic.</p>
    <p class="meta">Last updated: {lastUpdated}</p>
  </section>

  <aside class="beta-notice">
    <strong>⚠️ Heads up — LrGenius is currently in beta and under heavy development.</strong>
    The features listed for LrGenius below describe the direction of the project and what the current
    builds aim to do. Stability, quality and exact behaviour are still evolving from release to release,
    and the installers are not yet code-signed.
    Please <a href="https://github.com/LrGenius/LrGeniusAI/releases" target="_blank" rel="noopener">try the
    latest build</a> and verify that a given feature meets your needs before committing your workflow to it.
  </aside>

  <section class="intro">
    <p>
      The AI photo-workflow market has split into specialised tools: some focus on <strong>keywording and search</strong>,
      others on <strong>culling</strong>, others on <strong>editing in your personal style</strong>. This page summarises
      how <strong>LrGenius</strong> compares to the best-known products in each of those niches, so you can pick the
      right combination for your workflow.
    </p>
    <p>
      Most of the commercial tools on this page are mature, well-supported products with paying customers and years
      of polish. LrGenius is a much younger, free, open-source project — we are honest about that below and mark the
      areas that are still maturing.
    </p>
    <p>
      We try to stick to publicly verifiable facts. Features, pricing and product names change frequently — if you
      spot something out of date or inaccurate, please <a href="/contact">let us know</a> and we will correct it.
    </p>
  </section>

  <section class="categories">
    <h2>What each tool actually does</h2>
    <div class="cat-grid">
      <div class="cat-card">
        <h3>LrGenius <span class="badge">beta</span></h3>
        <p>Free, open-source Lightroom Classic plugin currently in active development. Aims to provide AI keywording,
          captions, titles, alt-text and semantic search today, with face recognition, AI culling and edit training
          ("Looks") evolving in newer builds. Works with local (Ollama, LM Studio) or cloud (ChatGPT, Gemini, Vertex AI)
          back-ends.</p>
      </div>
      <div class="cat-card">
        <h3>Excire Search / Foto</h3>
        <p>Commercial keywording, search and culling. Search is a Lightroom Classic plugin; Foto is a standalone
          DAM application. On-device AI, fixed trained keyword taxonomy, one-time purchase.</p>
      </div>
      <div class="cat-card">
        <h3>AnyVision (John R. Ellis)</h3>
        <p>Lightroom Classic plugin that uses Google Cloud Vision to tag photos, detect objects, logos, colours
          and to generate keywords / descriptions via prompts. Requires a Google Cloud API key and a paid plugin
          license.</p>
      </div>
      <div class="cat-card">
        <h3>Peakto (CYME)</h3>
        <p>Mac-focused universal photo organiser. Indexes Lightroom, Capture One, Apple Photos and many other
          catalogs into one searchable library, with local AI tagging, semantic search and AI culling.
          Subscription based.</p>
      </div>
      <div class="cat-card">
        <h3>Aftershoot</h3>
        <p>Dedicated AI culling (and increasingly editing/retouching) for high-volume photographers. Runs locally
          on your machine, detects duplicates, blur and closed eyes. Subscription.</p>
      </div>
      <div class="cat-card">
        <h3>Narrative Select</h3>
        <p>AI culling tool with "Scenes" grouping, close-up face checks and Personal AI Presets that hand off to
          Lightroom. Subscription, optional Pro tier for advanced features.</p>
      </div>
      <div class="cat-card">
        <h3>Imagen AI</h3>
        <p>Cloud-based AI editor that learns your personal editing style from your past Lightroom edits and applies
          it to new shoots. Also offers culling, cropping and masking. Pay-per-photo pricing.</p>
      </div>
      <div class="cat-card">
        <h3>Neurapix</h3>
        <p>German AI editing plugin for Lightroom. Trains a "SmartPreset" from 500+ of your previously edited images
          and applies your style to new shoots — up to ~600 images per minute. Also sells ready-made SmartPresets by
          professional photographers. Pay-per-image or monthly subscription.</p>
      </div>
    </div>
  </section>

