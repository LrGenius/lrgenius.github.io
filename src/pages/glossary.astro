---
import Layout from '../layouts/Layout.astro';

const terms = [
  {
    term: "AI Keywording",
    definition: "The automated generation of descriptive tags (keywords) for photos using an AI vision model. Unlike manual tagging, AI keywording analyzes the visual content of each image — subjects, scenes, colors, actions — and writes keyword metadata directly to the photo. LrGeniusAI uses open-vocabulary keywording, meaning it generates any relevant term rather than picking from a fixed list.",
    link: "/help/docs/help-analyze-and-index",
    linkText: "Analyze & Index guide"
  },
  {
    term: "Semantic Search",
    definition: "A way of searching a photo library by meaning or description rather than exact keyword matches. You describe what you remember — 'child running on a beach at sunset' — and the AI finds visually matching photos, even if those exact words were never used as keywords. Semantic search works by comparing the meaning of your query against the AI's understanding of each indexed image.",
    link: "/help/docs/help-advanced-search",
    linkText: "Advanced Search guide"
  },
  {
    term: "Culling",
    definition: "The process of selecting the best photos from a shoot and rejecting the rest — blurry shots, duplicates, eyes-closed frames, unflattering expressions. AI culling automates this first-pass selection by analyzing each image for sharpness, face quality, and composition. In LrGeniusAI, culling is face-aware, meaning the AI factors in whether eyes are open and in focus.",
    link: "/help/docs/help-cull-photos",
    linkText: "Cull Photos guide"
  },
  {
    term: "Embedding",
    definition: "A numerical representation of an image (or a piece of text) that captures its meaning as a list of numbers called a vector. AI search and semantic similarity work by comparing embeddings: if two photos have similar embeddings, they are visually or semantically similar. When LrGeniusAI indexes your library, it generates and stores an embedding for each photo so that semantic searches can run instantly later.",
    link: "/help/docs/help-analyze-and-index",
    linkText: "Analyze & Index guide"
  },
  {
    term: "Vision-Language Model (VLM)",
    definition: "An AI model that understands both images and text simultaneously. Instead of only recognizing objects from a fixed list, a VLM can describe what it sees in natural language, answer questions about an image, and generate contextually rich keywords and captions. LrGeniusAI supports multiple VLMs — local models via Ollama or LM Studio, and cloud models like GPT-4o and Gemini.",
    link: "/help/docs/help-choosing-ai-model",
    linkText: "Choosing an AI Model guide"
  },
  {
    term: "Ollama",
    definition: "An open-source runtime for running large language and vision models on your own hardware. Ollama handles model downloading, management, and a local API server, so applications like LrGeniusAI can send images to a local AI model without any internet connection. Running AI locally via Ollama means your photos never leave your computer.",
    link: "/help/docs/help-ollama-setup",
    linkText: "Ollama Setup guide"
  },
  {
    term: "LM Studio",
    definition: "A desktop application for running AI language and vision models locally on your own hardware, with a user-friendly interface for model management. LM Studio provides a local API compatible with the OpenAI format, which LrGeniusAI can connect to as an alternative to Ollama. Both Ollama and LM Studio allow fully offline, private AI processing.",
    link: "/help/docs/help-lm-studio-setup",
    linkText: "LM Studio Setup guide"
  },
  {
    term: "Open Vocabulary Keywording",
    definition: "AI keywording that generates any descriptive term the model considers relevant, rather than selecting from a predefined, closed list. Most traditional photo keywording tools use a fixed taxonomy — you can only get keywords that were explicitly included. Open-vocabulary models describe images in natural language, producing richer, more specific, and more accurate keywords for unusual subjects or niche genres.",
    link: "/help/docs/help-analyze-and-index",
    linkText: "Analyze & Index guide"
  },
  {
    term: "CLIP",
    definition: "Contrastive Language-Image Pretraining — a foundational AI model architecture developed by OpenAI that learns to understand images and text in a shared embedding space. Models trained with CLIP-style objectives can match images to textual descriptions and vice versa, which is the basis for semantic image search. Many vision-language models in LrGeniusAI build on CLIP-style training.",
    link: "/help/docs/help-choosing-ai-model",
    linkText: "Choosing an AI Model guide"
  },
  {
    term: "Face Recognition",
    definition: "The automatic detection and identification of people across a photo library. LrGeniusAI's face recognition groups photos by the people who appear in them, building a People cluster so you can quickly find all photos of a specific person without manual tagging. In culling mode, the AI also uses face detection to prioritize frames where the subject's eyes are sharp and open.",
    link: "/help/docs/help-people-faces",
    linkText: "People & Faces guide"
  },
  {
    term: "AI Caption",
    definition: "A natural-language sentence or short paragraph describing what is in a photo, generated by a vision-language model. Captions are more descriptive than keywords and can convey narrative context — 'A photographer adjusts camera settings on a tripod at dawn with mountains in the background.' LrGeniusAI can generate captions alongside keywords and write them to Lightroom's caption metadata field. Captions are also used as alt-text for web accessibility.",
    link: "/help/docs/help-analyze-and-index",
    linkText: "Analyze & Index guide"
  },
  {
    term: "Lightroom Classic Catalog",
    definition: "Adobe Lightroom Classic's database file that tracks the location of your photos, stores all edits, metadata, keywords, ratings, and organizational structure. Unlike Lightroom (cloud-based), Lightroom Classic keeps the catalog locally on your computer. LrGeniusAI is a plugin for Lightroom Classic that reads and writes keyword metadata and other fields directly into this catalog.",
    link: "/help/docs/getting-started",
    linkText: "Getting Started guide"
  },
  {
    term: "Keyword Deduplication",
    definition: "The process of identifying and merging duplicate, redundant, or near-identical keywords in a Lightroom catalog. Over time, catalogs accumulate variants like 'dog', 'dogs', and 'Dog' as separate entries — deduplication consolidates these into a single canonical keyword and re-applies it across all affected photos. LrGeniusAI includes a Keyword Dedup & De-Clutter tool for this purpose.",
    link: "/help/docs/help-keyword-dedup-and-declutter",
    linkText: "Keyword Dedup & De-Clutter guide"
  }
];
---

<Layout
  title="Photography AI Glossary — Key Terms for LrGeniusAI & Lightroom"
  description="Plain-English definitions of AI photography terms: semantic search, culling, embeddings, vision-language models, Ollama, CLIP, and more. Relevant to LrGeniusAI and Lightroom Classic."
>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lrgenius.com" },
      { "@type": "ListItem", "position": 2, "name": "Glossary", "item": "https://lrgenius.com/glossary" }
    ]
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    "name": "Photography AI Glossary",
    "description": "Key terms for AI-powered photo management and the LrGeniusAI plugin",
    "url": "https://lrgenius.com/glossary",
    "hasDefinedTerm": terms.map(t => ({
      "@type": "DefinedTerm",
      "name": t.term,
      "description": t.definition,
      "inDefinedTermSet": "https://lrgenius.com/glossary"
    }))
  })} />

  <section class="hero compact">
    <h1>Photography AI Glossary</h1>
    <p class="tagline">Plain-English definitions for AI photo management terms.</p>
  </section>

  <section class="intro">
    <p>
      LrGeniusAI brings concepts from AI and machine learning into your Lightroom workflow. This glossary
      explains the key terms you'll encounter — no prior AI knowledge required.
    </p>
  </section>

  <nav class="term-index" aria-label="Jump to term">
    <p>Jump to:</p>
    <ul>
      {terms.map(t => (
        <li><a href={`#${t.term.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{t.term}</a></li>
      ))}
    </ul>
  </nav>

  <section class="glossary-list">
    {terms.map(t => (
      <div class="glossary-entry" id={t.term.toLowerCase().replace(/[^a-z0-9]+/g, '-')}>
        <h2>{t.term}</h2>
        <p>{t.definition}</p>
        {t.link && (
          <p class="see-also">See also: <a href={t.link}>{t.linkText}</a></p>
        )}
      </div>
    ))}
  </section>

</Layout>

<style>
  .hero.compact {
    text-align: center;
    padding: 3rem 0 1rem;
  }
  .tagline {
    font-size: 1.25rem;
    color: #666;
    margin-bottom: 0.25rem;
  }
  .intro {
    padding: 1rem 0 1.5rem;
    max-width: 720px;
  }
  .term-index {
    background: #f8f9fa;
    border: 1px solid #eaeaea;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }
  .term-index p {
    margin: 0 0 0.5rem;
    font-weight: 600;
    color: #444;
  }
  .term-index ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 1rem;
  }
  .term-index li {
    margin: 0;
  }
  .term-index a {
    color: var(--color-primary, #0066cc);
    text-decoration: none;
  }
  .term-index a:hover {
    text-decoration: underline;
  }
  .glossary-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .glossary-entry {
    padding: 2rem 0;
    border-top: 1px solid #eaeaea;
    scroll-margin-top: 80px;
  }
  .glossary-entry h2 {
    margin-top: 0;
    font-size: 1.3rem;
    color: var(--color-primary, #0066cc);
  }
  .glossary-entry p {
    line-height: 1.7;
    color: #333;
    max-width: 720px;
  }
  .see-also {
    font-size: 0.88rem;
    color: #666;
  }
  .see-also a {
    color: var(--color-primary, #0066cc);
  }
</style>
