---
export function getStaticPaths() {
  const redirects: Record<string, string> = {
    // Legacy redirects — point to new /help/docs/ pages
    'choosing-ai-model': '/help/docs/Help-Choosing-AI-Model',
    'migration': '/help/docs/Getting-Started',
    'installation': '/help/docs/Getting-Started',
    'configuration': '/help/docs/Getting-Started',
    'ollama-setup': '/help/docs/Help-Ollama-Setup',
    'lmstudio-setup': '/help/docs/Help-LM-Studio-Setup',
    'tips-tricks': '/help/docs/Help-Analyze-and-Index',
    'faq': '/help/docs/FAQ',
    'troubleshooting': '/help/docs/Troubleshooting',
    'ai-edit': '/help/docs/Help-AI-Edit',
    'cull-photos': '/help/docs/Help-Cull-Photos',
    'advanced-search': '/help/docs/Help-Advanced-Search',
    'analyze-and-index': '/help/docs/Help-Analyze-and-Index',
  };

  return Object.entries(redirects).map(([slug, destination]) => ({
    params: { slug },
    props: { destination },
  }));
}

const { destination } = Astro.props;

return Astro.redirect(destination, 301);
---
