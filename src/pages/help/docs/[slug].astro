---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({
    params: { slug: doc.id },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const rawTitle = doc.data.title ?? doc.id;

const isFaq = doc.id === 'faq';
const isGettingStarted = doc.id === 'getting-started';

const titleMap: Record<string, string> = {
  'faq': 'LrGeniusAI FAQ — Frequently Asked Questions',
  'getting-started': 'Getting Started with LrGeniusAI for Lightroom Classic',
  'google-vertex-ai-login': 'Google Vertex AI Login & Setup for LrGeniusAI',
  'help-advanced-search': 'Advanced Semantic Photo Search in Lightroom Classic',
  'help-ai-edit': 'AI Edit Photos & Smart Develop Recipes in Lightroom',
  'help-analyze-and-index': 'Analyze & Index Photos for AI Keywording and Search',
  'help-choosing-ai-model': 'Choosing an AI Model: Local vs Cloud for Lightroom',
  'help-cull-photos': 'AI Photo Culling & Best Shot Selection in Lightroom',
  'help-find-similar': 'Find Similar Photos Across Your Lightroom Library',
  'help-keyword-dedup-and-declutter': 'Keyword Deduplication & Tag Cleanup for Lightroom',
  'help-lm-studio-setup': 'LM Studio Setup for Local AI in Lightroom Classic',
  'help-ollama-setup': 'Ollama Setup for Local AI in Lightroom Classic',
  'help-people-faces': 'Face Recognition & People Management in Lightroom',
  'help-train-from-edits': 'Save Edits as AI Training Examples for Lightroom',
  'troubleshooting': 'Troubleshooting LrGeniusAI — Common Errors & Fixes',
};

const title = titleMap[doc.id] ?? rawTitle;

const descriptionMap: Record<string, string> = {
  'faq': 'Frequently asked questions about LrGeniusAI — the free, open-source AI plugin for Lightroom Classic. Covers installation, AI model setup, privacy, photo culling, keyword generation, and more.',
  'getting-started': 'Step-by-step guide to installing and setting up LrGeniusAI for Adobe Lightroom Classic. Covers installation, bypassing security warnings, configuring AI providers, and indexing your first photos.',
  'google-vertex-ai-login': 'How to authenticate with Google Vertex AI for LrGeniusAI in Lightroom Classic. Step-by-step gcloud login instructions, service account setup, and troubleshooting tips for Vertex AI integration.',
  'help-advanced-search': 'How to use semantic free-text search in LrGeniusAI to find any photo in your Lightroom Classic library by describing it in plain language. Covers indexing, search tips, and compatible AI providers.',
  'help-ai-edit': "How to use LrGeniusAI's AI Edit feature to apply smart develop recipes and personal editing styles to photos in Lightroom Classic. Create, apply, and refine AI-generated editing presets (beta).",
  'help-analyze-and-index': "How to use LrGeniusAI's Analyze & Index feature to generate AI keywords, captions, titles, alt-text, and semantic embeddings for Lightroom Classic photos. Covers batch processing and provider options.",
  'help-choosing-ai-model': 'How to choose the best AI model for LrGeniusAI — compare local models via Ollama and LM Studio with cloud providers OpenAI ChatGPT, Google Gemini, and Vertex AI. Privacy, cost, and quality trade-offs explained.',
  'help-cull-photos': "How to use LrGeniusAI's AI photo culling to automatically select the best shots in Lightroom Classic. Covers face-aware selection, sharpness scoring, expression detection, and pick/reject workflows.",
  'help-find-similar': "How to use LrGeniusAI's Find Similar Images feature to discover visually similar photos across your entire Lightroom Classic catalog using AI-powered semantic embeddings and image similarity search.",
  'help-keyword-dedup-and-declutter': "How to use LrGeniusAI's keyword deduplication and de-clutter tools to merge duplicate tags, clean up keyword hierarchies, and tidy your Lightroom Classic keyword library for better catalog organization.",
  'help-lm-studio-setup': 'Step-by-step guide to setting up LM Studio as a local AI provider for LrGeniusAI. Run AI photo analysis, keyword generation, and semantic search 100% offline on macOS or Windows — no cloud uploads.',
  'help-ollama-setup': 'Step-by-step guide to setting up Ollama as a local AI provider for LrGeniusAI. Run AI keywording, semantic search, and photo culling 100% offline on your own hardware — no cloud subscription required.',
  'help-people-faces': "How to use LrGeniusAI's face recognition and People dialog to automatically cluster faces, identify individuals, and find specific people across your entire Lightroom Classic photo catalog.",
  'help-train-from-edits': 'How to save your Lightroom Classic develop edits as AI training examples in LrGeniusAI. Build a personal editing style that the plugin learns from and applies automatically to new photos.',
  'troubleshooting': 'Fix connection errors, installation issues, AI analysis failures, and common plugin problems in LrGeniusAI for Adobe Lightroom Classic. Step-by-step troubleshooting for Windows and macOS.',
};

const pageDescription = doc.data.description || descriptionMap[doc.id];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": new URL('/', Astro.site).href
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Help & Documentation",
      "item": new URL('/help', Astro.site).href
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": new URL(`/help/docs/${doc.id}`, Astro.site).href
    }
  ]
};

const faqSchema = isFaq ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is LrGeniusAI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LrGeniusAI is an AI extension for Adobe Lightroom Classic. It adds AI-powered metadata generation (keywords, titles, captions, alt-text), semantic free-text search, automatic develop edits, image culling, face/person management, and more — all running locally as a background server without freezing Lightroom."
      }
    },
    {
      "@type": "Question",
      "name": "Does LrGeniusAI send my photos to the cloud?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Only if you choose a cloud provider (ChatGPT/OpenAI, Google Gemini, Vertex AI). With local providers (Ollama, LM Studio) your photos never leave your machine. For cloud providers, images are sent to the respective API for analysis. Embeddings and all generated metadata are always stored locally on your computer."
      }
    },
    {
      "@type": "Question",
      "name": "Is LrGeniusAI free?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. LrGeniusAI is completely free and open-source under the AGPL-3.0 license. Cloud API usage (Gemini, OpenAI) incurs costs at the respective provider's standard rates. Local models via Ollama or LM Studio are completely free to run."
      }
    },
    {
      "@type": "Question",
      "name": "Does LrGeniusAI work offline without internet?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. When you configure Ollama or LM Studio as your AI provider, all image analysis, keyword generation, semantic search indexing, and culling happen entirely on your own hardware. No internet connection is required after the initial model download."
      }
    },
    {
      "@type": "Question",
      "name": "Which Lightroom version does LrGeniusAI support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Adobe Lightroom Classic only. Lightroom CC (cloud) and other Lightroom versions are not supported, as the plugin relies on the Lightroom Classic SDK."
      }
    },
    {
      "@type": "Question",
      "name": "Is the LrGeniusAI installer safe even though it's blocked by Windows or macOS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The installers are not code-signed (cost and complexity for an open-source project), which causes OS security warnings. On Windows SmartScreen, click 'More info' then 'Run anyway'. On macOS Gatekeeper, right-click the .pkg installer, select Open, then click Open anyway. Alternatively go to System Settings → Privacy & Security → Open Anyway."
      }
    },
    {
      "@type": "Question",
      "name": "What does 'Analyze & Index' do in LrGeniusAI?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It does two things in one pass: (1) Sends each photo to the configured AI model to generate keywords, title, caption, and alt text. (2) Creates a semantic embedding using SigLIP2 locally, so the photo can be found by Advanced Search. Both steps are optional and can be run independently."
      }
    },
    {
      "@type": "Question",
      "name": "Does LrGeniusAI culling delete photos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Culling is completely non-destructive. LrGeniusAI creates Lightroom collections (Picks, Alternates, Reject Candidates, optional Duplicates) — your original photos are never moved, renamed, or deleted."
      }
    },
    {
      "@type": "Question",
      "name": "Which AI models does LrGeniusAI support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "LrGeniusAI supports local models via Ollama and LM Studio (such as qwen3-vl), and cloud models including OpenAI/ChatGPT (gpt-4o, gpt-5), Google Gemini (gemini-2.5-flash, gemini-2.5-pro), and Google Vertex AI. You can switch providers at any time from the Plug-in Manager."
      }
    }
  ]
} : null;

const howToSchema = isGettingStarted ? {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Set Up LrGeniusAI for Adobe Lightroom Classic",
  "description": "Step-by-step guide to installing and configuring LrGeniusAI, the free open-source AI plugin for Adobe Lightroom Classic.",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Install Plugin and Server",
      "text": "Download the latest release from https://github.com/LrGenius/LrGeniusAI/releases. Install both the Lightroom Classic plugin (.lrdevplugin) and the Python backend server. If your OS shows a security warning: on macOS, right-click the .pkg → Open → Open anyway; on Windows, click More info → Run anyway in the SmartScreen prompt."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Configure Plugin",
      "text": "Open File → Plug-in Manager in Lightroom and find LrGeniusAI. Set the Backend Server URL (default: http://127.0.0.1:8000). Enter API keys for cloud providers (OpenAI, Google Gemini), or configure the URL for local providers (Ollama, LM Studio)."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Index Your Photos",
      "text": "Select one or more photos in the Lightroom Library grid. Navigate to Library → Plug-in Extras → Analyze & Index Photos. LrGeniusAI will generate keywords, captions, titles, alt-text, and semantic embeddings for each selected photo."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Use AI Search, Culling, and Metadata",
      "text": "After indexing, use Library → Plug-in Extras → Advanced Search to find photos by plain-language descriptions. Run Cull Photos to let AI pre-select your best shots. Use Retrieve Metadata to write AI-generated tags back into your Lightroom catalog."
    }
  ]
} : null;
---

<Layout title={`${title} - LrGeniusAI`} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  {howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
  <article class="doc-page">
    <div class="doc-breadcrumb">
      <a href="/help">Help</a> › {title}
    </div>
    <div class="doc-content">
      <Content />
    </div>
    <div class="doc-footer">
      <a
        href={`https://github.com/LrGenius/LrGeniusAI/wiki/${doc.id}`}
        target="_blank"
        rel="noopener noreferrer"
      >Edit this page on GitHub</a>
    </div>
  </article>
</Layout>

<style>
  .doc-page {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .doc-breadcrumb {
    font-size: 0.875rem;
    color: #888;
    margin-bottom: 2rem;
  }

  .doc-breadcrumb a {
    color: var(--color-primary, #0066cc);
    text-decoration: none;
  }

  .doc-breadcrumb a:hover {
    text-decoration: underline;
  }

  .doc-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .doc-content :global(h2) {
    font-size: 1.4rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #eaeaea;
  }

  .doc-content :global(h3) {
    font-size: 1.15rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .doc-content :global(p) {
    line-height: 1.75;
    margin-bottom: 1rem;
    color: #333;
  }

  .doc-content :global(ul),
  .doc-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .doc-content :global(li) {
    line-height: 1.7;
    margin-bottom: 0.25rem;
  }

  .doc-content :global(a) {
    color: var(--color-primary, #0066cc);
    text-decoration: none;
  }

  .doc-content :global(a:hover) {
    text-decoration: underline;
  }

  .doc-content :global(code) {
    background: #f5f5f5;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .doc-content :global(pre) {
    background: #f5f5f5;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .doc-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.85em;
  }

  .doc-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .doc-content :global(th) {
    text-align: left;
    padding: 0.6rem 0.75rem;
    background: #f5f5f5;
    border: 1px solid #e0e0e0;
    font-weight: 600;
  }

  .doc-content :global(td) {
    padding: 0.5rem 0.75rem;
    border: 1px solid #e0e0e0;
    vertical-align: top;
  }

  .doc-content :global(tr:nth-child(even) td) {
    background: #fafafa;
  }

  .doc-content :global(blockquote) {
    border-left: 4px solid #ddd;
    padding: 0.5rem 1rem;
    color: #666;
    margin: 1rem 0 1.5rem;
    background: #fafafa;
    border-radius: 0 4px 4px 0;
  }

  .doc-content :global(blockquote p) {
    margin-bottom: 0;
    color: #666;
  }

  .doc-content :global(hr) {
    border: none;
    border-top: 1px solid #eaeaea;
    margin: 2rem 0;
  }

  .doc-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #eaeaea;
    font-size: 0.875rem;
    color: #888;
  }

  .doc-footer a {
    color: #888;
    text-decoration: none;
  }

  .doc-footer a:hover {
    color: var(--color-primary, #0066cc);
    text-decoration: underline;
  }
</style>
