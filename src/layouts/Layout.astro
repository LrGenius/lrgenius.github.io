---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import '../styles/global.css';
import { SEO } from 'astro-seo';
import { useTranslations } from '../i18n/utils';

interface Props {
	title: string;
	description?: string;
}

const { title, description } = Astro.props;
const lang = Astro.currentLocale as 'en' | 'de';
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/lrgenius.png" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
		<meta name="keywords" content={t('seo.keywords')} />
		<SEO
			title={title}
			description={description || t('seo.default_description')}
			openGraph={{
				basic: {
					title: title,
					type: 'website',
					image: new URL('/lrgenius.png', Astro.site).href,
					url: Astro.url,
				},
				image: {
					alt: t('alt.logo'),
				}
			}}
			twitter={{
				card: 'summary_large_image',
				creator: '@lrgenius',
				site: '@lrgenius',
			}}
		/>

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "LrGeniusAI",
			"alternateName": "LrGenius",
			"url": "https://lrgenius.com",
			"downloadUrl": "https://github.com/LrGenius/LrGeniusAI/releases",
			"operatingSystem": "Windows, macOS",
			"applicationCategory": "MultimediaApplication",
			"applicationSubCategory": "Photography Plugin",
			"softwareRequirements": "Adobe Lightroom Classic",
			"license": "https://www.gnu.org/licenses/agpl-3.0.html",
			"softwareLicense": "AGPL-3.0",
			"isAccessibleForFree": true,
			"featureList": [
				"AI keyword generation for photos",
				"AI captions, titles and alt-text",
				"Semantic free-text search across photo library",
				"AI-powered photo culling with face-aware selection",
				"Face recognition and People management",
				"Smart editing recipes trained on personal editing style",
				"Keyword deduplication and de-clutter",
				"Local AI processing via Ollama",
				"Local AI processing via LM Studio",
				"Cloud AI via OpenAI / ChatGPT",
				"Cloud AI via Google Gemini",
				"Cloud AI via Google Vertex AI"
			],
			"offers": [
				{
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "USD"
				},
				{
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "EUR"
				}
			],
			"description": t('seo.default_description'),
			"author": {
				"@type": "Person",
				"name": "Bastian Machek",
				"url": "https://blog.fokuspunk.de",
				"sameAs": ["https://blog.fokuspunk.de", "https://github.com/fokuspunk"]
			},
			"publisher": {
				"@type": "Organization",
				"name": "LrGenius",
				"url": "https://lrgenius.com",
				"logo": {
					"@type": "ImageObject",
					"url": "https://lrgenius.com/lrgenius.png"
				},
				"sameAs": [
					"https://github.com/LrGenius",
					"https://x.com/lrgenius",
					"https://blog.fokuspunk.de"
				]
			}
		})} />

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "LrGenius",
			"url": "https://lrgenius.com",
			"logo": {
				"@type": "ImageObject",
				"url": "https://lrgenius.com/lrgenius.png"
			},
			"sameAs": [
				"https://github.com/LrGenius",
				"https://x.com/lrgenius",
				"https://blog.fokuspunk.de"
			],
			"founder": {
				"@type": "Person",
				"name": "Bastian Machek",
				"url": "https://blog.fokuspunk.de"
			}
		})} />

		<!-- Google Analytics with Consent Mode v2 (default denied; CookieBanner updates on accept) -->
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){ dataLayer.push(arguments); }
			window.gtag = gtag;

			const stored = localStorage.getItem('cookie-consent');
			const analyticsGranted = stored === 'accepted' ? 'granted' : 'denied';

			gtag('consent', 'default', {
				ad_storage: 'denied',
				ad_user_data: 'denied',
				ad_personalization: 'denied',
				analytics_storage: analyticsGranted,
				wait_for_update: 500,
			});

			gtag('js', new Date());
			gtag('config', 'G-3T09LKYR2E', { anonymize_ip: true });
		</script>
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-3T09LKYR2E"></script>

	</head>
	<body>
    <Header />
		<main class="container">
			<slot />
		</main>
    <Footer />
		<CookieBanner />
	</body>
</html>
