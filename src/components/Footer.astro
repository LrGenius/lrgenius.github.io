---
import { useTranslations } from '../i18n/utils';

const lang = Astro.currentLocale as 'en' | 'de';
const t = useTranslations(lang);

const base = `/${lang}`;
---
<footer>
  <div class="container footer-container">
    <div class="footer-brand">
      <img src="/lrgenius.png" alt={t('alt.logo')} width="30" height="30">
      <span>LrGenius</span>
    </div>
    <div class="footer-links">
      <a href="/compare">Compare AI plugins for Lightroom</a>
      <a href="/lrgenius-vs-excire">LrGenius vs. Excire &amp; others</a>
      <a href="/help">Help &amp; Docs</a>
    </div>
  </div>
  <div class="container footer-disclosure">
    We improve our products by using <a href="https://clarity.microsoft.com" target="_blank" rel="noopener">Microsoft Clarity</a> to see how you use our website. By using our site, you agree that we and Microsoft can collect and use this data. <a href="https://privacy.microsoft.com/privacystatement" target="_blank" rel="noopener">Microsoft Privacy Statement</a>.
  </div>
</footer>

<style>
  footer {
    background-color: #f8f9fa;
    border-top: 1px solid #eaeaea;
    padding: 2rem 0;
    margin-top: 4rem;
    font-size: 0.9rem;
    color: #6c757d;
  }

 .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
  }

 .footer-brand {
    display: flex;
    align-items: center;
    font-weight: bold;
  }

 .footer-brand img {
    margin-right: 8px;
  }

 .footer-links a,.footer-social a {
    color: #6c757d;
    margin: 0 10px;
  }
  
 .footer-links a:hover,.footer-social a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .footer-disclosure {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid #eaeaea;
    font-size: 0.8rem;
    color: #999;
    text-align: center;
  }

  .footer-disclosure a {
    color: #999;
    text-decoration: underline;
  }

  .footer-disclosure a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
   .footer-container {
      flex-direction: column;
      text-align: center;
    }
   .footer-brand,.footer-links,.footer-social {
      margin-bottom: 1rem;
    }
  }
</style>